    {
      "name": "Sales",
      "item": [
        {
          "name": "Create Sale",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('saleNumber', 'SALE-' + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('saleId', json.data.id);",
                  "    if (json.data.items && json.data.items.length > 0) {",
                  "        pm.collectionVariables.set('saleItemId', json.data.items[0].id);",
                  "    }",
                  "}",
                  "pm.test('10% discount applied for 5 items', function () {",
                  "    var item = json.data.items[0];",
                  "    pm.expect(item.discount).to.eql(0.10);",
                  "    pm.expect(item.totalAmount).to.eql(5 * 109.95 * 0.90);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/sales",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"saleNumber\": \"{{saleNumber}}\",\n  \"saleDate\": \"{{today}}\",\n  \"customerId\": \"{{userId}}\",\n  \"customerName\": \"John Doe\",\n  \"branchId\": \"00000000-0000-0000-0000-000000000001\",\n  \"branchName\": \"Main Branch\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"productName\": \"Fjallraven Backpack\",\n      \"quantity\": 5,\n      \"unitPrice\": 109.95\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get All Sales",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is paginated', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('currentPage');",
                  "    pm.expect(json).to.have.property('totalItems');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/sales?_page=1&_size=10",
              "query": [
                { "key": "_page", "value": "1" },
                { "key": "_size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Sale by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response contains sale id', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('id');",
                  "    pm.expect(json.data.id).to.eql(pm.collectionVariables.get('saleId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/sales/{{saleId}}"
          }
        },
        {
          "name": "Update Sale",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('saleNumber', 'SALE-' + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () { pm.response.to.have.status(200); });",
                  "pm.test('20% discount applied for 10 items', function () {",
                  "    var item = pm.response.json().data.items[0];",
                  "    pm.expect(item.discount).to.eql(0.20);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/sales/{{saleId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"saleNumber\": \"{{saleNumber}}\",\n  \"saleDate\": \"{{today}}\",\n  \"customerId\": \"{{userId}}\",\n  \"customerName\": \"John Doe Updated\",\n  \"branchId\": \"00000000-0000-0000-0000-000000000001\",\n  \"branchName\": \"Main Branch\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"productName\": \"Fjallraven Backpack\",\n      \"quantity\": 10,\n      \"unitPrice\": 109.95\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Cancel Sale Item",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () { pm.response.to.have.status(200); });"
