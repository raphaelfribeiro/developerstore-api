{
  "info": {
    "name": "DeveloperStore API",
    "description": "Complete API collection for the DeveloperStore challenge — Sales, Carts, Products, Users and Auth endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "productId", "value": "", "type": "string" },
    { "key": "cartId", "value": "", "type": "string" },
    { "key": "saleId", "value": "", "type": "string" },
    { "key": "saleItemId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('userId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"raphaelribeiro\",\n  \"email\": \"raphaelfribeiro@gmail.com\",\n  \"password\": \"Test@123456\",\n  \"phone\": \"+5547936183255\",\n  \"role\": 1,\n  \"status\": 1\n}"
            }
          }
        },
        {
          "name": "Authenticate",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"raphaelfribeiro@gmail.com\",\n  \"password\": \"Test@123456\"\n}"
            }
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('productId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Fjallraven Backpack\",\n  \"price\": 109.95,\n  \"description\": \"Your perfect pack for everyday use and long walks in the forest.\",\n  \"category\": \"men's clothing\",\n  \"image\": \"https://fakestoreapi.com/img/81fAn9YpKsL._AC_UX679_.jpg\",\n  \"rating\": {\n    \"rate\": 3.9,\n    \"count\": 120\n  }\n}"
            }
          }
        },
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/products?page=1&size=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/products/categories"
          }
        },
        {
          "name": "Get Products by Category",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/products/category/men's clothing?page=1&size=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/products/{{productId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Fjallraven Backpack - Updated\",\n  \"price\": 129.95,\n  \"description\": \"Updated description.\",\n  \"category\": \"men's clothing\",\n  \"image\": \"https://fakestoreapi.com/img/81fAn9YpKsL._AC_UX679_.jpg\",\n  \"rating\": {\n    \"rate\": 4.2,\n    \"count\": 150\n  }\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "Carts",
      "item": [
        {
          "name": "Create Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('cartId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/carts",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"date\": \"2026-05-11T10:00:00Z\",\n  \"products\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 3\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get All Carts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/carts?page=1&size=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Cart by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/carts/{{cartId}}"
          }
        },
        {
          "name": "Update Cart",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/carts/{{cartId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"date\": \"2026-05-11T10:10:10Z\",\n  \"products\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 5\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Delete Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/carts/{{cartId}}"
          }
        }
      ]
    },
    {
      "name": "Sales",
      "item": [
        {
          "name": "Create Sale",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('saleId', json.data.id);",
                  "    if (json.data.items && json.data.items.length > 0) {",
                  "        pm.collectionVariables.set('saleItemId', json.data.items[0].id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/sales",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"saleNumber\": \"SALE-001\",\n  \"saleDate\": \"2026-05-11T10:00:00Z\",\n  \"customerId\": \"{{userId}}\",\n  \"customerName\": \"John Doe\",\n  \"branchId\": \"00000000-0000-0000-0000-000000000001\",\n  \"branchName\": \"Main Branch\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"productName\": \"Fjallraven Backpack\",\n      \"quantity\": 5,\n      \"unitPrice\": 109.95\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get All Sales",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/sales?page=1&size=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Sale by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/sales/{{saleId}}"
          }
        },
        {
          "name": "Update Sale",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/sales/{{saleId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"saleNumber\": \"SALE-001\",\n  \"saleDate\": \"2026-05-11T10:00:00Z\",\n  \"customerId\": \"{{userId}}\",\n  \"customerName\": \"John Doe Updated\",\n  \"branchId\": \"00000000-0000-0000-0000-000000000001\",\n  \"branchName\": \"Main Branch\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"productName\": \"Fjallraven Backpack\",\n      \"quantity\": 10,\n      \"unitPrice\": 109.95\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Cancel Sale Item",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/sales/{{saleId}}/items/{{saleItemId}}/cancel"
          }
        },
        {
          "name": "Delete Sale",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/sales/{{saleId}}"
          }
        }
      ]
    }
  ]
}
