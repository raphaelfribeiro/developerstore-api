          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/sales/{{saleId}}/items/{{saleItemId}}/cancel"
          }
        },
