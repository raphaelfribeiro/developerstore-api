# =============================================================
# DeveloperStore API — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# The application works out-of-the-box with the defaults below.
# Change only what you need for your environment.
# =============================================================

# -------------------------------------------------------------
# PostgreSQL
# -------------------------------------------------------------
POSTGRES_DB=developer_evaluation
POSTGRES_USER=developer
POSTGRES_PASSWORD=ev@luAt10n

# -------------------------------------------------------------
# MongoDB
# -------------------------------------------------------------
MONGO_USER=developer
MONGO_PASSWORD=ev@luAt10n

# -------------------------------------------------------------
# Redis
# -------------------------------------------------------------
REDIS_PASSWORD=ev@luAt10n

# -------------------------------------------------------------
# JWT Authentication
# IMPORTANT: Replace JWT_SECRET_KEY with a strong random string
# of at least 32 characters before deploying to any environment.
# Minimum 32 bytes required for HS256 (RFC 7518).
# -------------------------------------------------------------
JWT_SECRET_KEY=YourSuperSecretKeyForJwtTokenGenerationThatShouldBeAtLeast32BytesLong
JWT_ISSUER=AmbevDeveloperEvaluation
JWT_AUDIENCE=AmbevDeveloperEvaluationUsers
JWT_EXPIRY_MINUTES=60
